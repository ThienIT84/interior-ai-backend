# External API Configuration
REPLICATE_API_TOKEN=your_replicate_token_here
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Inpainting Method Selection
# Primary variable: REMOVE_OBJECT_METHOD
# Options: "lama", "replicate", "local", "auto"
# - "lama": Fast object removal via Replicate LaMa
# - "local": Always use local GPU (15 min, FREE)
# - "replicate": Always use Replicate API (10 sec, $0.01/image)
# - "auto": Use lama if available, then replicate, then local
REMOVE_OBJECT_METHOD=lama

# Legacy alias (backward compatibility only). Leave empty by default.
INPAINTING_METHOD=

# Segmentation Backend Selection
# Options: "local", "sam3_replicate"
# - "local": Use SAM (segment-anything) on this machine
# - "sam3_replicate": Use SAM3 model on Replicate cloud
SEGMENTATION_BACKEND=local

# If SAM3 Replicate fails, fallback to local SAM automatically
SEGMENTATION_FALLBACK_TO_LOCAL=true

# Pinned SAM3 model version on Replicate
SAM3_REPLICATE_MODEL=mattsays/sam3-image:d73db077226443ba4fafd34e233b3626b552eac2a433f90c7c32a9ac89bd9e72

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Redis for async jobs (Option 2: Docker Redis mapped to localhost:6380)
REDIS_URL=redis://127.0.0.1:6380/0

# Model Paths
SAM_CHECKPOINT_PATH=weights/sam_vit_b_01ec64.pth

# Data Directories
DATA_DIR=data
INPUTS_DIR=data/inputs
OUTPUTS_DIR=data/outputs
MASKS_DIR=data/masks
TEMP_DIR=data/temp

# Image Processing
JPEG_QUALITY=95
MAX_IMAGE_SIZE=2048
