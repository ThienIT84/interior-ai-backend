# External API Configuration
REPLICATE_API_TOKEN=your_replicate_token_here
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Inpainting Method Selection
# Options: "local", "replicate", "auto"
# - "local": Always use local GPU (15 min, FREE)
# - "replicate": Always use Replicate API (10 sec, $0.01/image)
# - "auto": Use Replicate if available, fallback to local (RECOMMENDED)
INPAINTING_METHOD=auto

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Model Paths
SAM_CHECKPOINT_PATH=weights/sam_vit_b_01ec64.pth

# Data Directories
DATA_DIR=data
INPUTS_DIR=data/inputs
OUTPUTS_DIR=data/outputs
MASKS_DIR=data/masks
TEMP_DIR=data/temp

# Image Processing
JPEG_QUALITY=95
MAX_IMAGE_SIZE=2048
